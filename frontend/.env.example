# =============================================================================
# Frontend environment variables
# Copy to `.env` (or `.env.production` for the deployed build) and fill in.
# All Vite-exposed vars must be prefixed with VITE_.
# =============================================================================

# Base URL of the deployed backend REST API (no trailing slash).
# Local dev:   http://localhost:5000/api
# Production:  https://<your-service>.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# Base URL of the deployed backend Socket.IO server (no trailing slash).
# Must NOT include the /api path — the Socket.IO client connects to the
# server root, and the same origin serves both REST and WS.
VITE_SOCKET_URL=http://localhost:5000
